# Dependencies
node_modules/

# Build output
dist/

# Environment / secrets
.env
.env.local
*.pem
*.key

# WhatsApp (Baileys) auth state — contains session credentials, NEVER commit
# (anchored to repo root: src/auth/ is source code and must be tracked)
/auth/
/whatsapp-auth/
.wwebjs_auth/

# Logs
logs/
*.log

# Local model cache (transformers.js)
.cache/
models/

# Server-side scratch state (untracked so the redeploy clean-tree check never
# trips on it) — e.g. the default community-context export target, issue #108
/var/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# ============================================================================
# Community Agent — environment configuration
# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).
# ============================================================================

# --- Claude / LLM auth (subscription) -------------------------------------
# Generate with:  claude setup-token   (on a machine where you're logged in)
# This authenticates the Agent SDK against your Claude subscription.
CLAUDE_CODE_OAUTH_TOKEN=

# Model to use for the agent. claude-sonnet-5 is agentic-optimised and the
# best price/capability fit; claude-opus-4-8 for harder work.
AGENT_MODEL=claude-sonnet-5

# Optional per-tier override of AGENT_MODEL for member/guest turns — the
# highest-volume, lowest-trust tier, same role split AGENT_MAX_TURNS_MEMBER
# already applies below. Lets an operator spend less of the shared weekly Max
# pool on member/guest turns while keeping admin/super_admin on AGENT_MODEL.
# Unset/empty (default) = every role uses AGENT_MODEL, unchanged.
AGENT_MODEL_MEMBER=

# Optional override of AGENT_MODEL for the two tool-less, single-turn,
# fixed-format background classifier calls: the moderation LLM abuse check
# and the context-builder cluster summariser. Unlike AGENT_MODEL_MEMBER
# (keyed to caller role), these jobs have no caller role, so this is a
# separate opt-in knob. Unset/empty (default) = both calls use AGENT_MODEL,
# unchanged.
AGENT_MODEL_CLASSIFIER=

# Max agentic turns per request (safety cap). admin/super_admin only —
# member/guest turns use the lower AGENT_MAX_TURNS_MEMBER below.
AGENT_MAX_TURNS=12

# Max agentic turns for member/guest turns — the highest-volume, lowest-trust
# tier, restricted to the narrower MEMBER_TOOLS surface with no WebSearch.
# Deliberately lower than AGENT_MAX_TURNS (see docs/SECURITY.md §3).
AGENT_MAX_TURNS_MEMBER=6

# --- Discord ---------------------------------------------------------------
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Your guild (server) ID. Restricts the bot to a single server.
DISCORD_GUILD_ID=
# Optional: only respond in these channel IDs (comma-separated). Empty = all.
DISCORD_ALLOWED_CHANNEL_IDS=
# Send a static welcome DM to new server joiners. Off by default.
DISCORD_WELCOME_ENABLED=false
# Fallback text channel to post the welcome in if the DM fails (DMs closed).
DISCORD_WELCOME_CHANNEL_ID=
# Auto-enroll every new Discord joiner as a gated-mode member (Discord only —
# WhatsApp has no join event) instead of leaving them a gated guest until an
# admin runs add_member. This grants standing member-tier access to EVERYONE
# who joins the server without any per-person admin review, and commits
# reply/token budget (shared Max pool) to conversing with those unvetted
# joiners — enable only if you intend the server to be open-enrollment. A
# removed member who rejoins while this is on is re-enrolled; use Discord's
# ban to keep someone out durably. Off by default.
DISCORD_AUTO_ENROLL_MEMBERS=false
# Ambient archiving: store EVERY message in allowed guild channels (including
# from non-members) for community memory, not just messages addressing the
# bot. Deletes/edits on Discord delete/update the stored copy. PRECONDITION:
# post the community notice from docs/SECURITY.md (server rules / pinned
# message) BEFORE enabling — this changes the gated-mode privacy posture.
DISCORD_ARCHIVE_ALL_MESSAGES=false
# Auto-moderation: scan every message for bad language / abuse, warn the
# member, and after MODERATION_STRIKE_LIMIT active strikes assign a muted role
# that blocks posting until an admin clears their warnings. Off by default.
# PRECONDITION before enabling: (1) post a community notice that messages are
# scanned (privacy posture change, like archiving), and (2) grant the bot the
# Manage Roles + Manage Channels permissions (needed for the muted role and the
# auto-created mod-alerts channel). Admins and super admins are never warned.
DISCORD_MODERATION_ENABLED=false
# Extra bad-language/slur terms (comma-separated), matched case-insensitively
# as whole words on top of a small built-in default list. Community-specific
# slurs go here rather than in source.
MODERATION_BAD_WORDS=
# Active strikes at which the member is muted (blocked from posting).
MODERATION_STRIKE_LIMIT=3
# Optional rolling window (days): only strikes newer than this count toward
# MODERATION_STRIKE_LIMIT. Unset = unbounded (every uncleared strike counts
# forever, regardless of age). Never auto-unmutes — clear_warnings is still
# required to lift a mute even after strikes decay below the limit.
MODERATION_STRIKE_WINDOW_DAYS=
# Names of the role and private channel the bot creates on demand.
MODERATION_MUTED_ROLE_NAME=Muted
MODERATION_ADMIN_CHANNEL_NAME=mod-alerts
# Stage 2 (opt-in): escalate messages the wordlist does NOT catch to an LLM
# abuse classifier — one Claude call per escalated message on the shared Max
# pool, so enable deliberately. Stage 1 (wordlist) runs regardless.
MODERATION_LLM_ABUSE_ENABLED=false

# --- Image generation (Grok Build CLI) ------------------------------------
# Admin/super-admin `generate_image` tool. OFF by default. Requires the `grok`
# CLI installed on the host and signed in (`grok login --device-auth`) with a
# SuperGrok subscription — no API key, uses the subscription.
IMAGE_GEN_ENABLED=false
# Path to the grok binary (the service user must be able to run it). On a live
# deploy set an ABSOLUTE path (e.g. /opt/community-agent/home/.grok/bin/grok),
# not a bare `grok`: a bare name is PATH-resolved and a writable PATH entry
# could shadow it with a hostile binary run as the service user. See SECURITY.md.
GROK_BIN=grok
# Hard timeout for one image generation, in ms.
IMAGE_GEN_TIMEOUT_MS=180000
# Max images one admin can generate per UTC day (abuse cap on top of the
# one-in-flight-per-user guard). 0 = unlimited.
IMAGE_GEN_DAILY_LIMIT=25

# --- GitHub issue filing (suggest_issue) ----------------------------------
# Lets a SUPER ADMIN file an issue on the repo straight from chat. OFF by
# default. GITHUB_ISSUE_TOKEN must be a FINE-GRAINED PAT scoped to
# `Issues: write` on GITHUB_ISSUE_REPO ONLY (never the CLAUDE_CODE_OAUTH_TOKEN)
# — see docs/DEPLOYMENT.md. This is the bot's only GitHub egress / write token.
GITHUB_ISSUE_ENABLED=false
GITHUB_ISSUE_REPO=swampratnz/community-agent
GITHUB_ISSUE_TOKEN=
# Labels applied to every filed issue (comma-separated). Default
# community-feedback so it enters the research pipeline as evidence.
GITHUB_ISSUE_LABELS=community-feedback
# Max issues one super admin can file per rolling calendar day (0 = unlimited).
GITHUB_ISSUE_DAILY_LIMIT=10

# --- Dev-team dispatch service (super-admin dev_team_* tools) --------------
# Lets a SUPER ADMIN drive a remote "dev-team" build service over the tailnet
# from chat: dispatch an assess/deliver job, check status, fetch the result. A
# background poller DMs the requester when a (~20 min) run finishes. OFF by
# default. deliver is additionally CONFIRM-gated (it makes changes / opens a
# PR). See docs/SECURITY.md.
DEV_TEAM_ENABLED=false
# Base URL of the dev-team service. This is a tailnet-INTERNAL endpoint reached
# only over Tailscale (WireGuard-encrypted, device-authenticated), so http://
# is allowed here — unlike the public-internet DOCS_INGEST/STATUS_CHECK URLs
# there is deliberately NO https-only enforcement. Required when enabled.
DEV_TEAM_ENDPOINT_URL=
# Bearer token sent on every request except GET /health. A CREDENTIAL: kept out
# of logs and covered by the outbound secret-redaction layer. Required when
# enabled.
DEV_TEAM_AUTH_TOKEN=
# How often the completion-DM poller re-checks unnotified job watches (minutes).
DEV_TEAM_WATCH_POLL_MINUTES=1
# Rolling calendar-day cap on dev_team_dispatch calls per super admin
# (0 = unlimited). Bounds how often an injected instruction reaching a
# super-admin turn could fire cost-incurring remote jobs.
DEV_TEAM_DAILY_LIMIT=10

# --- WhatsApp (Baileys provider) ------------------------------------------
WHATSAPP_PROVIDER=baileys
# Directory where Baileys stores its linked-device credentials.
WHATSAPP_AUTH_DIR=./whatsapp-auth
# Optional allowlist of numbers/groups the bot will respond to. Empty = all DMs.
WHATSAPP_ALLOWED_JIDS=
# Post a static welcome message to a group when someone joins it. Off by
# default. This adds an UNPROMPTED, event-triggered automated group post to
# the unofficial Baileys path (see docs/SECURITY.md) — operator-gated and
# cooldown-bounded, but not risk-free. Never DMs the new joiner directly.
WHATSAPP_WELCOME_ENABLED=false
# Minimum minutes between welcome posts to the same group (collapses a burst
# of sequential joins into one message instead of one per join).
WHATSAPP_WELCOME_COOLDOWN_MINUTES=180
# Ambient archiving parity for WhatsApp groups (issue #103, extends #48):
# comma-separated allowlist of group JIDs (e.g. 123456789-1234@g.us) to
# archive EVERY message in — including from gated-mode guests — with an
# embedding and its WhatsApp message id. Deletes/edits on WhatsApp
# delete/update the stored copy. 1:1 DMs are never archived. Empty (default)
# = feature fully off, zero behaviour change. PRECONDITION: post the
# WhatsApp community notice from docs/SECURITY.md in a group BEFORE adding
# its JID here — this changes the gated-mode privacy posture for that group.
WHATSAPP_ARCHIVE_GROUP_JIDS=
# Voice-note transcription (Baileys only), OFF by default. When on, an
# eligible caller's voice note is transcribed locally (transformers.js
# Whisper — no external API, no extra key, audio never leaves the host) and
# actioned as if typed. The tier gate is enforced BEFORE any media is
# downloaded, so a below-tier voice note is never fetched or transcribed.
# Requires ffmpeg on the host (see docs/DEPLOYMENT.md). See docs/SECURITY.md §13.
WHATSAPP_VOICE_ENABLED=false
# Whisper model (downloaded once to the transformers cache, like the embedding
# model). *.en variants are English-only and faster; drop the .en for
# multilingual. Alternatives: Xenova/whisper-small.en (more accurate, slower).
WHATSAPP_VOICE_MODEL=Xenova/whisper-base.en
# Voice notes longer than this (seconds) are ignored WITHOUT downloading —
# bounds per-note transcription cost.
WHATSAPP_VOICE_MAX_SECONDS=120
# Minimum tier eligible for voice transcription (issue #507). Defaults to
# super_admin — byte-identical to the original super-admin-only feature (pure
# env check, no DB call). Lowering to admin/member/guest opens on-demand local
# Whisper inference to a larger, less-trusted population — pair with a
# non-zero WHATSAPP_VOICE_RATE_LIMIT_PER_HOUR below. One of: super_admin,
# admin, member, guest.
WHATSAPP_VOICE_MIN_ROLE=super_admin
# Rolling hourly cap on transcribed voice notes PER SENDER (0 = unlimited,
# this repo's usual "0/unset = off" convention). Only bites once
# WHATSAPP_VOICE_MIN_ROLE is lowered below super_admin. Recommended non-zero
# whenever minRole is widened — see the residual-risk note in docs/SECURITY.md §13.
WHATSAPP_VOICE_RATE_LIMIT_PER_HOUR=0

# --- RBAC (three tiers: super_admin > admin > member) -----------------------
# Super admins are env-only (cannot be granted via chat). They grant admins;
# admins add members. Comma-separated.
SUPER_ADMIN_DISCORD_IDS=
# Phone numbers, E.164 without +, e.g. 64211234567
SUPER_ADMIN_WHATSAPP_NUMBERS=
# 'gated' = only registered members get replies (guests are told to ask an
# admin, and their messages are NOT stored). 'open' = anyone can ask.
ACCESS_MODE_DISCORD=gated
ACCESS_MODE_WHATSAPP=gated

# --- WhatsApp Cloud API (required if WHATSAPP_PROVIDER=cloud) --------------
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_APP_SECRET=
WHATSAPP_CLOUD_WEBHOOK_PORT=8080
# Send a static first-contact welcome the first time a number ever messages
# the bot (the Cloud API has no group-join event, so a sender's own first
# inbound message is used instead). Off by default; zero behaviour change
# until enabled.
WHATSAPP_CLOUD_WELCOME_ENABLED=false

# --- Database (PostgreSQL + pgvector) -------------------------------------
DATABASE_URL=postgres://community_agent:CHANGE_ME@localhost:5432/community_agent
# Embedding model (transformers.js, runs locally). 384 dims for all-MiniLM-L6-v2.
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIM=384
# Pool-level query/connection bounds (issue #502) — a stuck lock wait, stalled
# network round-trip, or slow autovacuum can otherwise hang a connection
# forever, wedging the whole pool. Generous defaults sized well above any
# legitimate query this codebase runs; on by default, no behaviour change for
# any query that completes normally.
# DB_STATEMENT_TIMEOUT_MS=15000
# DB_QUERY_TIMEOUT_MS=15000
# DB_CONNECT_TIMEOUT_MS=10000

# --- Behaviour -------------------------------------------------------------
# Number of past interactions to retrieve as memory context.
MEMORY_TOP_K=6
# Cosine-similarity floor (0-1) for memory recall/remember_search. 0 = no
# floor (default, byte-identical to today's behaviour).
MEMORY_RELEVANCE_THRESHOLD=0
# Max agent replies per user per rolling 24h (0 = unlimited; super admins exempt).
DAILY_REPLY_LIMIT_PER_USER=50
# Start a fresh Claude session past either cap (context/injection hygiene).
SESSION_MAX_TURNS=30
SESSION_MAX_AGE_HOURS=24
# Age-based purge of raw `interactions` (privacy/retention). Unset/0 = disabled.
# Must be 0 or >= 7 if set. knowledge/admin_audit/sessions are never touched.
INTERACTION_RETENTION_DAYS=
# Age-based purge of server_roster rows for members who have LEFT
# (left_at IS NOT NULL). Unset/0 = disabled. Must be 0 or >= 30 if set.
# Currently-present members are never touched regardless of this setting.
ROSTER_DEPARTED_RETENTION_DAYS=
# A platform disconnected continuously past this many minutes triggers one
# debounced super-admin DM alert (via whichever adapter is still up).
HEALTH_ALERT_AFTER_MINUTES=5
# Unauthenticated GET /healthz -> {status, db, adapters}. Unset = disabled
# (no listening port). If set, bind to localhost and put a reverse proxy in
# front — same guidance as the WhatsApp Cloud webhook port.
HEALTH_PORT=
# Offline context builder: a ~daily in-process job that clusters stored
# interactions and distills recurring topics into durable context_digests
# (read via the admin list_context_digests tool). Off by default. Cost is
# hard-capped in code: at most CONTEXT_BUILDER_MAX_SUMMARIES short tool-less
# model calls per run (worst case ≈ max_summaries small Claude calls/day from
# the shared Max pool), and a run is skipped entirely while the
# USAGE_ALERT_DAILY_REPLIES threshold is breached.
CONTEXT_BUILDER_ENABLED=false
CONTEXT_BUILDER_WINDOW_DAYS=1
CONTEXT_BUILDER_MAX_SUMMARIES=5
# Minimum distinct authors a topic cluster needs before it is digested (>=2),
# so a digest can never become a profile of one prolific person.
CONTEXT_BUILDER_MIN_DISTINCT_USERS=3
# Knowledge-candidate review queue (issue #102, the deferred half of #51):
# for each digest the builder writes, its SAME summarisation call also drafts
# a Q&A candidate when the cluster is one stable, answerable question — no
# extra model call, so the CONTEXT_BUILDER_MAX_SUMMARIES worst case above is
# unchanged with this on. Candidates land in knowledge_candidates as
# 'pending'; nothing reaches knowledge/knowledge_search until an admin calls
# accept_knowledge_candidate (list/decline are also admin-only). Off by
# default, and has no effect while CONTEXT_BUILDER_ENABLED is false.
CONTEXT_CANDIDATES_ENABLED=false
# Daily knowledge refresh: a scheduled job web-researches a small FIXED set of
# fast-moving Claude/Anthropic topics and writes each briefing straight into the
# knowledge base as one upserted, clearly-labelled 'auto-researched' entry per
# topic. Off by default. IMPORTANT: unlike the candidate queue above, this path
# has NO human review gate — entries are published without approval (which is
# why they carry an explicit machine-generated/unverified label). The topic list
# is fixed in code (not configurable here) to bound what can ever be researched,
# and a ~daily freshness guard makes it redeploy-safe. See docs/SECURITY.md.
KNOWLEDGE_REFRESH_ENABLED=false
# Max agentic turns for one topic's web-research call (bounds per-run cost).
KNOWLEDGE_REFRESH_MAX_TURNS=10
# Docs ingest: backfill Anthropic's official developer docs into the knowledge
# base as RAG chunks, refreshed ~weekly with a content diff so only changed
# sections re-embed (the created/updated/removed counts are the "what changed"
# view). Off by default. Reads ONE fixed official source over HTTPS — the
# llms.txt index below, then each page's `.md`; no model in the loop, and the
# URLs are not chat/env-steerable content. Entries are written with a 'docs'
# provenance and treated as TRUSTED at retrieval (Anthropic's own docs), unlike
# the quarantined open-web 'auto' refresh. See docs/SECURITY.md.
DOCS_INGEST_ENABLED=false
# Official machine-readable docs index. Fixed default; override only if it moves.
DOCS_INGEST_INDEX_URL=https://platform.claude.com/llms.txt
# Safety caps so a bloated index can't run away.
DOCS_INGEST_MAX_PAGES=2500
DOCS_INGEST_MAX_CHUNKS=20000
# Concurrent page fetches — small, to be polite to the docs host.
DOCS_INGEST_CONCURRENCY=5
# Doc-path prefixes to EXCLUDE (comma-separated). The default drops the
# auto-generated per-language SDK/CLI reference — ~90% of the corpus by volume
# and near-useless for a chat bot — keeping the conceptual guides + core API.
# Set empty to ingest the whole corpus. Tune to taste (e.g. drop api/go but keep
# api/python by removing it from this list).
DOCS_INGEST_EXCLUDE_PATHS=api/go,api/csharp,api/java,api/python,api/typescript,api/ruby,api/php,api/cli,api/compliance
# Knowledge link-rot check: a ~weekly job HEAD-checks every knowledge entry's
# sourceUrl and flags dead citations for admin review (list_knowledge
# sourceUnreachable filter). Off by default. sourceUrl is admin-authored only
# (save_knowledge/update_knowledge/accept_knowledge_candidate, or docs-ingest's
# own fixed source), and every request goes through an SSRF guard (https-only,
# DNS-checked against a private/internal denylist on the initial URL and every
# redirect hop) before issuing. No model in the loop; response bodies are
# never read. See docs/SECURITY.md.
KNOWLEDGE_LINK_CHECK_ENABLED=false
# Anthropic status check: poll Anthropic's own public status page on a
# background timer and expose the cached result via the member-tier
# check_status tool, so "is this me or an Anthropic incident" gets an
# authoritative answer without widening WebSearch (admin+ only) to every
# member. Off by default. Reads ONE fixed official HTTPS source; no model in
# the fetch/parse loop. A member's turn only ever reads the in-memory cache,
# never triggers a live fetch. See docs/SECURITY.md.
STATUS_CHECK_ENABLED=false
# Anthropic's official Statuspage summary endpoint. Fixed default; override
# only if Anthropic moves it.
STATUS_CHECK_API_URL=https://status.claude.com/api/v2/summary.json
# How often to re-poll, in minutes.
STATUS_CHECK_POLL_MINUTES=5
# Anonymised community-context export, regenerated after each producing
# builder run so the research loop can ground proposals in real community
# need. Aggregate-only + k-floored + PII-scrubbed in code. K=3 default: small
# enough to keep signal in a modest community, large enough that no one
# person's activity becomes an identifiable line. See SECURITY.md before
# enabling. CONTEXT_EXPORT_PATH defaults to an UNTRACKED var/ file — do NOT
# point it at docs/COMMUNITY-CONTEXT.md on a live deploy, or the unattended
# exporter will dirty that tracked file and wedge the nightly redeploy's
# clean-tree check (issue #108). Refresh the committed docs file yourself,
# on your own cadence, with CONTEXT_EXPORT_PATH=docs/COMMUNITY-CONTEXT.md
# npm run export:context, then review and commit.
CONTEXT_EXPORT_ENABLED=false
CONTEXT_EXPORT_WINDOW_DAYS=30
CONTEXT_EXPORT_MIN_DISTINCT_USERS=3
CONTEXT_EXPORT_PATH=var/community-context.md
# Proactive super-admin DM alert when the rolling-24h outbound reply count
# reaches this threshold. Unset/0 = disabled (default; no timer, no extra
# queries). Reply count is a coarse proxy for shared Max-pool draw, not an
# exact token reading — tune to your own community's traffic.
USAGE_ALERT_DAILY_REPLIES=
# When a member's agent turn fails because the query() call hit an upstream
# Claude usage-limit/overload condition (rate limit, 429, overloaded_error,
# quota), the member is told this honestly instead of the generic internal-
# error reply. This flag additionally DMs super admins, debounced to one per
# ongoing window (silent re-arm once turns succeed again). Off by default,
# consistent with this repo's convention for new proactive DMs.
UPSTREAM_LIMIT_ALERT_ENABLED=false
# Proactive super-admin DM alert when listAdminRoster() (the same data
# backing the list_admins tool) shows one or more current admins have left
# the server/group but still hold bot-admin privilege via DM. Debounced to
# one DM per crossing (silent re-arm once every departed admin is revoked
# or reinstated, i.e. the count returns to exactly 0). Off by default,
# consistent with this repo's convention for new proactive DMs — see
# docs/ARCHITECTURE.md "Departed-admin alert".
DEPARTED_ADMIN_ALERT_ENABLED=false
# Weekly proactive super-admin DM pushing the guild-wide engagement
# percentage that the super-admin-only, pull-only engagement_stats tool
# (issue #419) already computes on demand. At most one DM per super admin
# per platform per 7 days (restart-safe, persisted freshness guard). A
# static current-percentage snapshot only — no week-over-week trend in v1.
# Off by default, consistent with this repo's convention for new proactive
# DMs — see docs/ARCHITECTURE.md "Engagement alert".
ENGAGEMENT_ALERT_ENABLED=false
# Weekly proactive DM to each admin (community_users role='admin') summarising
# recurring-question clusters in their own scoped conversations — a push
# companion to the on-demand question_digest tool. Off by default (no timer,
# no extra queries). Super admins are not enrolled; they keep the on-demand,
# all-conversation-scoped question_digest tool instead.
ADMIN_DIGEST_ENABLED=false
# Week-over-week trend suffix on every admin-digest count (issue #497). Off by
# default: when unset, the prior week's snapshot is never read and no digest
# line ever gains a trend suffix — output stays byte-identical to today. The
# snapshot itself is still written every run regardless of this flag, so
# flipping it on is retroactively useful from the very next weekly tick.
ADMIN_DIGEST_TRENDS_ENABLED=false
# Fifth admin-digest signal: nudge admins toward knowledge entries neither
# edited nor retrieved in this many days, so a stale FAQ entry gets a push
# reminder instead of only being visible via an on-demand list_knowledge
# eyeball. 0 (unset) = disabled, zero behaviour change. If set, must be >= 30.
KNOWLEDGE_STALE_DAYS=
# Absolute content-age ceiling, OR-ed into the same staleness check as
# KNOWLEDGE_STALE_DAYS above: fires on a popular entry's edit age alone, even
# when it's retrieved often enough that KNOWLEDGE_STALE_DAYS's clock never
# lapses. 0 (unset) = disabled, zero behaviour change. If set, must be >= 90,
# and must be >= a nonzero KNOWLEDGE_STALE_DAYS.
KNOWLEDGE_STALE_MAX_AGE_DAYS=
# Skip the agent turn (and its query() spawn against the shared Max pool) for
# pure acknowledgements ("thanks", "ok", "👍") that carry no other content —
# sends one static reply instead. Off by default; see docs/ARCHITECTURE.md
# "Known cost/latency characteristic" and src/ackClassifier.ts.
ACK_SHORTCUT_ENABLED=false
# Skip the agent turn (and its query() spawn) when a message near-exactly
# matches an existing knowledge entry — replies with that entry's content
# directly instead. Off by default; see docs/ARCHITECTURE.md "Known
# cost/latency characteristic" and src/router.ts.
KNOWLEDGE_SHORTCUT_ENABLED=false
# Cosine-similarity floor (0-1) for the shortcut above — deliberately much
# stricter than the 0.35 knowledge_search relevance floor, since this gates
# an unsupervised full-turn skip rather than a hedged suggestion.
KNOWLEDGE_SHORTCUT_THRESHOLD=0.9
# Member-facing low-rated-answer caveat (issue #337): when the knowledge
# shortcut above serves an entry whose global unhelpfulCount is at/above
# this threshold, append a fixed caveat clause nudging the member to
# rate_answer it too. 0 (unset) = disabled, zero behaviour change. If set,
# must be >= 2, so a single rater can never trigger it.
KNOWLEDGE_LOW_RATED_CAVEAT_MIN_UNHELPFUL=
# Cap on how many titles the member-facing list_knowledge_topics tool returns
# in one reply (issue #437) — a titles-only browse of the knowledge base.
# Always-on with a sane default (unlike the 0-disables knobs above).
KNOWLEDGE_TOPICS_LIST_LIMIT=50
# Extend the knowledge shortcut above to gated guests, restricted to
# scope='global' entries only, ahead of the static "ask an admin" pointer.
# Reuses KNOWLEDGE_SHORTCUT_THRESHOLD. Off by default; see docs/ARCHITECTURE.md
# "Known cost/latency characteristic" and src/router.ts.
GUEST_KNOWLEDGE_SHORTCUT_ENABLED=false
# Skip a second full agent turn when the SAME caller resends the exact same
# text again shortly after a turn that failed on error_max_turns — replies
# with the same canned "too many steps" message instead of guaranteeing
# another full spent AGENT_MAX_TURNS budget. Off by default; see
# docs/ARCHITECTURE.md and src/router.ts.
REPEAT_MAX_TURNS_SHORTCUT_ENABLED=false
# Log level: trace|debug|info|warn|error
LOG_LEVEL=info
# Set to "true" to pretty-print logs (dev only).
LOG_PRETTY=false

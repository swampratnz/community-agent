# ============================================================================
# Community Agent — environment configuration
# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).
# ============================================================================

# --- Claude / LLM auth (subscription) -------------------------------------
# Generate with:  claude setup-token   (on a machine where you're logged in)
# This authenticates the Agent SDK against your Claude subscription.
CLAUDE_CODE_OAUTH_TOKEN=

# Model to use for the agent. claude-sonnet-5 is agentic-optimised and the
# best price/capability fit; claude-opus-4-8 for harder work.
AGENT_MODEL=claude-sonnet-5

# Max agentic turns per request (safety cap).
AGENT_MAX_TURNS=12

# --- Discord ---------------------------------------------------------------
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Your guild (server) ID. Restricts the bot to a single server.
DISCORD_GUILD_ID=
# Optional: only respond in these channel IDs (comma-separated). Empty = all.
DISCORD_ALLOWED_CHANNEL_IDS=
# Send a static welcome DM to new server joiners. Off by default.
DISCORD_WELCOME_ENABLED=false
# Fallback text channel to post the welcome in if the DM fails (DMs closed).
DISCORD_WELCOME_CHANNEL_ID=
# Ambient archiving: store EVERY message in allowed guild channels (including
# from non-members) for community memory, not just messages addressing the
# bot. Deletes/edits on Discord delete/update the stored copy. PRECONDITION:
# post the community notice from docs/SECURITY.md (server rules / pinned
# message) BEFORE enabling — this changes the gated-mode privacy posture.
DISCORD_ARCHIVE_ALL_MESSAGES=false
# Auto-moderation: scan every message for bad language / abuse, warn the
# member, and after MODERATION_STRIKE_LIMIT active strikes assign a muted role
# that blocks posting until an admin clears their warnings. Off by default.
# PRECONDITION before enabling: (1) post a community notice that messages are
# scanned (privacy posture change, like archiving), and (2) grant the bot the
# Manage Roles + Manage Channels permissions (needed for the muted role and the
# auto-created mod-alerts channel). Admins and super admins are never warned.
DISCORD_MODERATION_ENABLED=false
# Extra bad-language/slur terms (comma-separated), matched case-insensitively
# as whole words on top of a small built-in default list. Community-specific
# slurs go here rather than in source.
MODERATION_BAD_WORDS=
# Active strikes at which the member is muted (blocked from posting).
MODERATION_STRIKE_LIMIT=3
# Names of the role and private channel the bot creates on demand.
MODERATION_MUTED_ROLE_NAME=Muted
MODERATION_ADMIN_CHANNEL_NAME=mod-alerts
# Stage 2 (opt-in): escalate messages the wordlist does NOT catch to an LLM
# abuse classifier — one Claude call per escalated message on the shared Max
# pool, so enable deliberately. Stage 1 (wordlist) runs regardless.
MODERATION_LLM_ABUSE_ENABLED=false

# --- Image generation (Grok Build CLI) ------------------------------------
# Admin/super-admin `generate_image` tool. OFF by default. Requires the `grok`
# CLI installed on the host and signed in (`grok login --device-auth`) with a
# SuperGrok subscription — no API key, uses the subscription.
IMAGE_GEN_ENABLED=false
# Path to the grok binary (the service user must be able to run it). On a live
# deploy set an ABSOLUTE path (e.g. /opt/community-agent/home/.grok/bin/grok),
# not a bare `grok`: a bare name is PATH-resolved and a writable PATH entry
# could shadow it with a hostile binary run as the service user. See SECURITY.md.
GROK_BIN=grok
# Hard timeout for one image generation, in ms.
IMAGE_GEN_TIMEOUT_MS=180000
# Max images one admin can generate per UTC day (abuse cap on top of the
# one-in-flight-per-user guard). 0 = unlimited.
IMAGE_GEN_DAILY_LIMIT=25

# --- WhatsApp (Baileys provider) ------------------------------------------
WHATSAPP_PROVIDER=baileys
# Directory where Baileys stores its linked-device credentials.
WHATSAPP_AUTH_DIR=./whatsapp-auth
# Optional allowlist of numbers/groups the bot will respond to. Empty = all DMs.
WHATSAPP_ALLOWED_JIDS=
# Post a static welcome message to a group when someone joins it. Off by
# default. This adds an UNPROMPTED, event-triggered automated group post to
# the unofficial Baileys path (see docs/SECURITY.md) — operator-gated and
# cooldown-bounded, but not risk-free. Never DMs the new joiner directly.
WHATSAPP_WELCOME_ENABLED=false
# Minimum minutes between welcome posts to the same group (collapses a burst
# of sequential joins into one message instead of one per join).
WHATSAPP_WELCOME_COOLDOWN_MINUTES=180
# Ambient archiving parity for WhatsApp groups (issue #103, extends #48):
# comma-separated allowlist of group JIDs (e.g. 123456789-1234@g.us) to
# archive EVERY message in — including from gated-mode guests — with an
# embedding and its WhatsApp message id. Deletes/edits on WhatsApp
# delete/update the stored copy. 1:1 DMs are never archived. Empty (default)
# = feature fully off, zero behaviour change. PRECONDITION: post the
# WhatsApp community notice from docs/SECURITY.md in a group BEFORE adding
# its JID here — this changes the gated-mode privacy posture for that group.
WHATSAPP_ARCHIVE_GROUP_JIDS=

# --- RBAC (three tiers: super_admin > admin > member) -----------------------
# Super admins are env-only (cannot be granted via chat). They grant admins;
# admins add members. Comma-separated.
SUPER_ADMIN_DISCORD_IDS=
# Phone numbers, E.164 without +, e.g. 64211234567
SUPER_ADMIN_WHATSAPP_NUMBERS=
# 'gated' = only registered members get replies (guests are told to ask an
# admin, and their messages are NOT stored). 'open' = anyone can ask.
ACCESS_MODE_DISCORD=gated
ACCESS_MODE_WHATSAPP=gated

# --- WhatsApp Cloud API (required if WHATSAPP_PROVIDER=cloud) --------------
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_APP_SECRET=
WHATSAPP_CLOUD_WEBHOOK_PORT=8080

# --- Database (PostgreSQL + pgvector) -------------------------------------
DATABASE_URL=postgres://community_agent:CHANGE_ME@localhost:5432/community_agent
# Embedding model (transformers.js, runs locally). 384 dims for all-MiniLM-L6-v2.
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Behaviour -------------------------------------------------------------
# Number of past interactions to retrieve as memory context.
MEMORY_TOP_K=6
# Max agent replies per user per rolling 24h (0 = unlimited; super admins exempt).
DAILY_REPLY_LIMIT_PER_USER=50
# Start a fresh Claude session past either cap (context/injection hygiene).
SESSION_MAX_TURNS=30
SESSION_MAX_AGE_HOURS=24
# Age-based purge of raw `interactions` (privacy/retention). Unset/0 = disabled.
# Must be 0 or >= 7 if set. knowledge/admin_audit/sessions are never touched.
INTERACTION_RETENTION_DAYS=
# Age-based purge of server_roster rows for members who have LEFT
# (left_at IS NOT NULL). Unset/0 = disabled. Must be 0 or >= 30 if set.
# Currently-present members are never touched regardless of this setting.
ROSTER_DEPARTED_RETENTION_DAYS=
# A platform disconnected continuously past this many minutes triggers one
# debounced super-admin DM alert (via whichever adapter is still up).
HEALTH_ALERT_AFTER_MINUTES=5
# Unauthenticated GET /healthz -> {status, db, adapters}. Unset = disabled
# (no listening port). If set, bind to localhost and put a reverse proxy in
# front — same guidance as the WhatsApp Cloud webhook port.
HEALTH_PORT=
# Offline context builder: a ~daily in-process job that clusters stored
# interactions and distills recurring topics into durable context_digests
# (read via the admin list_context_digests tool). Off by default. Cost is
# hard-capped in code: at most CONTEXT_BUILDER_MAX_SUMMARIES short tool-less
# model calls per run (worst case ≈ max_summaries small Claude calls/day from
# the shared Max pool), and a run is skipped entirely while the
# USAGE_ALERT_DAILY_REPLIES threshold is breached.
CONTEXT_BUILDER_ENABLED=false
CONTEXT_BUILDER_WINDOW_DAYS=1
CONTEXT_BUILDER_MAX_SUMMARIES=5
# Minimum distinct authors a topic cluster needs before it is digested (>=2),
# so a digest can never become a profile of one prolific person.
CONTEXT_BUILDER_MIN_DISTINCT_USERS=3
# Knowledge-candidate review queue (issue #102, the deferred half of #51):
# for each digest the builder writes, its SAME summarisation call also drafts
# a Q&A candidate when the cluster is one stable, answerable question — no
# extra model call, so the CONTEXT_BUILDER_MAX_SUMMARIES worst case above is
# unchanged with this on. Candidates land in knowledge_candidates as
# 'pending'; nothing reaches knowledge/knowledge_search until an admin calls
# accept_knowledge_candidate (list/decline are also admin-only). Off by
# default, and has no effect while CONTEXT_BUILDER_ENABLED is false.
CONTEXT_CANDIDATES_ENABLED=false
# Daily knowledge refresh: a scheduled job web-researches a small FIXED set of
# fast-moving Claude/Anthropic topics and writes each briefing straight into the
# knowledge base as one upserted, clearly-labelled 'auto-researched' entry per
# topic. Off by default. IMPORTANT: unlike the candidate queue above, this path
# has NO human review gate — entries are published without approval (which is
# why they carry an explicit machine-generated/unverified label). The topic list
# is fixed in code (not configurable here) to bound what can ever be researched,
# and a ~daily freshness guard makes it redeploy-safe. See docs/SECURITY.md.
KNOWLEDGE_REFRESH_ENABLED=false
# Max agentic turns for one topic's web-research call (bounds per-run cost).
KNOWLEDGE_REFRESH_MAX_TURNS=10
# Anonymised community-context export, regenerated after each producing
# builder run so the research loop can ground proposals in real community
# need. Aggregate-only + k-floored + PII-scrubbed in code. K=3 default: small
# enough to keep signal in a modest community, large enough that no one
# person's activity becomes an identifiable line. See SECURITY.md before
# enabling. CONTEXT_EXPORT_PATH defaults to an UNTRACKED var/ file — do NOT
# point it at docs/COMMUNITY-CONTEXT.md on a live deploy, or the unattended
# exporter will dirty that tracked file and wedge the nightly redeploy's
# clean-tree check (issue #108). Refresh the committed docs file yourself,
# on your own cadence, with CONTEXT_EXPORT_PATH=docs/COMMUNITY-CONTEXT.md
# npm run export:context, then review and commit.
CONTEXT_EXPORT_ENABLED=false
CONTEXT_EXPORT_WINDOW_DAYS=30
CONTEXT_EXPORT_MIN_DISTINCT_USERS=3
CONTEXT_EXPORT_PATH=var/community-context.md
# Proactive super-admin DM alert when the rolling-24h outbound reply count
# reaches this threshold. Unset/0 = disabled (default; no timer, no extra
# queries). Reply count is a coarse proxy for shared Max-pool draw, not an
# exact token reading — tune to your own community's traffic.
USAGE_ALERT_DAILY_REPLIES=
# When a member's agent turn fails because the query() call hit an upstream
# Claude usage-limit/overload condition (rate limit, 429, overloaded_error,
# quota), the member is told this honestly instead of the generic internal-
# error reply. This flag additionally DMs super admins, debounced to one per
# ongoing window (silent re-arm once turns succeed again). Off by default,
# consistent with this repo's convention for new proactive DMs.
UPSTREAM_LIMIT_ALERT_ENABLED=false
# Weekly proactive DM to each admin (community_users role='admin') summarising
# recurring-question clusters in their own scoped conversations — a push
# companion to the on-demand question_digest tool. Off by default (no timer,
# no extra queries). Super admins are not enrolled; they keep the on-demand,
# all-conversation-scoped question_digest tool instead.
ADMIN_DIGEST_ENABLED=false
# Skip the agent turn (and its query() spawn against the shared Max pool) for
# pure acknowledgements ("thanks", "ok", "👍") that carry no other content —
# sends one static reply instead. Off by default; see docs/ARCHITECTURE.md
# "Known cost/latency characteristic" and src/ackClassifier.ts.
ACK_SHORTCUT_ENABLED=false
# Skip the agent turn (and its query() spawn) when a message near-exactly
# matches an existing knowledge entry — replies with that entry's content
# directly instead. Off by default; see docs/ARCHITECTURE.md "Known
# cost/latency characteristic" and src/router.ts.
KNOWLEDGE_SHORTCUT_ENABLED=false
# Cosine-similarity floor (0-1) for the shortcut above — deliberately much
# stricter than the 0.35 knowledge_search relevance floor, since this gates
# an unsupervised full-turn skip rather than a hedged suggestion.
KNOWLEDGE_SHORTCUT_THRESHOLD=0.9
# Log level: trace|debug|info|warn|error
LOG_LEVEL=info
# Set to "true" to pretty-print logs (dev only).
LOG_PRETTY=false
